RewriteEngine On
RewriteBase /

# --- 1) Redirections SEO (doivent être AVANT les tests -f/-d) ---

# /public/page  ->  /page (301)
RewriteCond %{THE_REQUEST} \s/+public/([^\s]+)\s [NC]
RewriteRule ^public/(.+)$ /$1 [R=301,L]

# /page.php  ->  /page (301)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.php[\s?] [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# --- 2) Gérer la racine (/) proprement ---
# Si tu as index.php à la racine, il sera servi via DirectoryIndex.
# Mais si tu veux être robuste même si tout passe par /public, décommente la ligne ci-dessous :
# RewriteRule ^$ public/index.php [L]

# --- 3) Si fichier/dossier existe, on ne réécrit pas ---
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --- 4) /page -> /page.php (si existe à la racine)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# --- 5) /page -> /public/page.php (si existe dans public/)
RewriteCond %{DOCUMENT_ROOT}/public/$1.php -f
RewriteRule ^(.+?)/?$ public/$1.php [L]

# --- 6) Fallback (si tu as un routeur/contrôleur frontal)
# Si tu as un public/index.php qui gère tout, décommente :
# RewriteRule ^ public/index.php [L]